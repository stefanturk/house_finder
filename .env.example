# Copy this file to .env and fill in your actual credentials
# This file will be loaded automatically by the scripts

# ── API Keys ──────────────────────────────────────────────────────────────

# PRIMARY: private-zillow (250 requests/month free tier)
# Capabilities: /search/bypolygon, /propimages, /walk_transit_bike
RAPIDAPI_KEY_PRIVATE_ZILLOW=your_private_zillow_key_here

# ENRICHMENT: US Property Market (600 requests/month)
# Capabilities: /property (descriptions), /photos, /walkTransitBikeScores
# (Does NOT support polygon search — enrichment only)
RAPIDAPI_KEY_US_PROPERTY_MARKET=your_us_property_market_key_here

# FALLBACK: ZLLW Working API (limited quota, often hits 429)
# Capabilities: /search/bypolygon (used only if private-zillow fails)
RAPIDAPI_KEY_ZLLW=your_zllw_working_key_here

# ── Claude API ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email Setup (via Resend API) ──────────────────────────────────────────

# Sign up at https://resend.com for a free API key
RESEND_API_KEY=re_your_resend_api_key_here
