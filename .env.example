# Copy this file to .env and fill in your actual credentials
# This file will be loaded automatically by the scripts

# ── API Keys ──────────────────────────────────────────────────────────────

# PRIMARY: ZLLW Working API — polygon-based property search
RAPIDAPI_KEY=your_zllw_working_key_here

# BACKUP #1: US Property Market — property photos + walk/transit/bike scores
# (Does NOT support polygon search — enrichment only)
RAPIDAPI_KEY_BACKUP=your_us_property_market_key_here

# BACKUP #2: private-zillow — polygon search + photos + walk/transit/bike scores
# (Used as first backup if primary fails)
RAPIDAPI_KEY_BACKUP2=your_private_zillow_key_here

# ── Claude API ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email Setup (via Resend API) ──────────────────────────────────────────

# Sign up at https://resend.com for a free API key
RESEND_API_KEY=re_your_resend_api_key_here
