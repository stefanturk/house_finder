# Copy this file to .env and fill in your actual credentials
# This file will be loaded automatically by the scripts

# Primary Zillow API (ZLLW Working by ggogle)
RAPIDAPI_KEY=your_primary_key_here

# Backup Zillow API (Zillow56 by apiheya — fallback on primary failure)
# Optional: if not set, only primary API is used
RAPIDAPI_KEY_BACKUP=your_backup_key_here
RAPIDAPI_HOST_BACKUP=zillow56.p.rapidapi.com

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email setup (via Resend API)
# Sign up at https://resend.com for a free API key
RESEND_API_KEY=re_your_resend_api_key_here
